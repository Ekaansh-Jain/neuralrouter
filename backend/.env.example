# ── Provider mode ───────────────────────────────────────────────
# "mock"  -> no API keys needed; simulates latency + occasional failures (great for demos)
# "live"  -> calls real Groq / OpenRouter using the keys below
PROVIDER_MODE=mock

# ── Provider API keys (only needed when PROVIDER_MODE=live) ───────
GROQ_API_KEY=
OPENROUTER_API_KEY=

# ── Supabase (optional) ──────────────────────────────────────────
# Leave blank to use the built-in in-memory store (data resets on restart).
SUPABASE_URL=
SUPABASE_KEY=

# ── Pipeline tuning ──────────────────────────────────────────────
REQUEST_DEADLINE_SECONDS=25.0
MAX_CONCURRENT_PROVIDER_CALLS=5
CACHE_TTL_SECONDS=3600
EVALUATOR_SAMPLE_RATE=0.1
CIRCUIT_FAILURE_THRESHOLD=3
CIRCUIT_RESET_SECONDS=30.0

# ── CORS ─────────────────────────────────────────────────────────
# Comma-separated list of allowed origins for the dashboard.
CORS_ORIGINS=http://localhost:5173
